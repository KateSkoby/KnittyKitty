<Window
    x:Class="KnittyKitty.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Knitty Kitty">

    <Grid x:Name="Root" Background="{StaticResource AppBackgroundBrush}">
        <Grid x:Name="AuthRoot" Padding="28">
            <Grid.Background>
                <ImageBrush ImageSource="Assets/AuthBackground.png" Stretch="UniformToFill" Opacity="0.72" />
            </Grid.Background>

            <Grid x:Name="AuthContent" MaxWidth="540" HorizontalAlignment="Center" VerticalAlignment="Center" RowSpacing="18">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel HorizontalAlignment="Center" Spacing="8">
                    <Image x:Name="AuthLogo" Source="Assets/BrandLogo.png" Width="390" Height="330" Stretch="Uniform" />
                    <TextBlock Text="Войдите или создайте профиль" Style="{StaticResource MutedTextStyle}" FontSize="15" HorizontalAlignment="Center" />
                </StackPanel>

                <Border x:Name="AuthPanel" Grid.Row="1" Background="{StaticResource AuthPanelBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="8" Padding="24">
                    <Grid RowSpacing="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Button
                                Command="{Binding ShowLoginCommand}"
                                Opacity="{Binding IsLoginMode, Converter={StaticResource BooleanToOpacityConverter}}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                HorizontalAlignment="Stretch">
                                <StackPanel Orientation="Horizontal" Spacing="7" HorizontalAlignment="Center">
                                    <SymbolIcon Symbol="Contact" Foreground="{StaticResource InkBrush}" />
                                    <TextBlock Text="Вход" FontWeight="Bold" />
                                </StackPanel>
                            </Button>

                            <Button
                                Grid.Column="1"
                                Command="{Binding ShowRegisterCommand}"
                                Opacity="{Binding IsRegisterMode, Converter={StaticResource BooleanToOpacityConverter}}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                HorizontalAlignment="Stretch">
                                <StackPanel Orientation="Horizontal" Spacing="7" HorizontalAlignment="Center">
                                    <SymbolIcon Symbol="AddFriend" Foreground="{StaticResource InkBrush}" />
                                    <TextBlock Text="Регистрация" FontWeight="Bold" />
                                </StackPanel>
                            </Button>
                        </Grid>

                        <InfoBar
                            Grid.Row="1"
                            IsOpen="{Binding HasStatusMessage}"
                            Severity="{Binding StatusSeverity}"
                            Title="{Binding StatusTitle}"
                            Message="{Binding StatusMessage}" />

                        <StackPanel Grid.Row="2" Spacing="12" Visibility="{Binding IsLoginMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBox
                                x:Name="LoginEmailBox"
                                Header="Почта"
                                PlaceholderText="name@example.com"
                                BorderBrush="{Binding IsLoginEmailInvalid, Converter={StaticResource BooleanToValidationBrushConverter}}"
                                BorderThickness="2"
                                LostFocus="LoginEmailBox_LostFocus"
                                Text="{Binding LoginEmail, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock
                                Text="{Binding LoginEmailHint}"
                                Foreground="#C42B1C"
                                FontSize="12"
                                FontWeight="SemiBold"
                                Visibility="{Binding IsLoginEmailInvalid, Converter={StaticResource BooleanToVisibilityConverter}}" />

                            <PasswordBox
                                x:Name="LoginPasswordBox"
                                Header="Пароль"
                                BorderBrush="{Binding IsLoginPasswordInvalid, Converter={StaticResource BooleanToValidationBrushConverter}}"
                                BorderThickness="2"
                                LostFocus="LoginPasswordBox_LostFocus"
                                PasswordChanged="LoginPasswordBox_PasswordChanged" />
                            <TextBlock
                                Text="{Binding LoginPasswordHint}"
                                Foreground="#C42B1C"
                                FontSize="12"
                                FontWeight="SemiBold"
                                Visibility="{Binding IsLoginPasswordInvalid, Converter={StaticResource BooleanToVisibilityConverter}}" />

                            <Button Command="{Binding LoginCommand}" Style="{StaticResource PrimaryButtonStyle}" HorizontalAlignment="Stretch">
                                <StackPanel Orientation="Horizontal" Spacing="7" HorizontalAlignment="Center">
                                    <SymbolIcon Symbol="Forward" Foreground="{StaticResource InkBrush}" />
                                    <TextBlock Text="Войти в магазин" FontWeight="Bold" />
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <StackPanel Grid.Row="3" Spacing="12" Visibility="{Binding IsRegisterMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBox
                                x:Name="RegisterNameBox"
                                Header="Имя"
                                PlaceholderText="Ваше имя"
                                BorderBrush="{Binding IsRegisterNameInvalid, Converter={StaticResource BooleanToValidationBrushConverter}}"
                                BorderThickness="2"
                                LostFocus="RegisterNameBox_LostFocus"
                                Text="{Binding RegisterName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock
                                Text="{Binding RegisterNameHint}"
                                Foreground="#C42B1C"
                                FontSize="12"
                                FontWeight="SemiBold"
                                Visibility="{Binding IsRegisterNameInvalid, Converter={StaticResource BooleanToVisibilityConverter}}" />

                            <TextBox
                                x:Name="RegisterEmailBox"
                                Header="Почта"
                                PlaceholderText="name@example.com"
                                BorderBrush="{Binding IsRegisterEmailInvalid, Converter={StaticResource BooleanToValidationBrushConverter}}"
                                BorderThickness="2"
                                LostFocus="RegisterEmailBox_LostFocus"
                                Text="{Binding RegisterEmail, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock
                                Text="{Binding RegisterEmailHint}"
                                Foreground="#C42B1C"
                                FontSize="12"
                                FontWeight="SemiBold"
                                Visibility="{Binding IsRegisterEmailInvalid, Converter={StaticResource BooleanToVisibilityConverter}}" />

                            <PasswordBox
                                x:Name="RegisterPasswordBox"
                                Header="Пароль"
                                BorderBrush="{Binding IsRegisterPasswordInvalid, Converter={StaticResource BooleanToValidationBrushConverter}}"
                                BorderThickness="2"
                                LostFocus="RegisterPasswordBox_LostFocus"
                                PasswordChanged="RegisterPasswordBox_PasswordChanged" />
                            <TextBlock
                                Text="{Binding RegisterPasswordHint}"
                                Foreground="#C42B1C"
                                FontSize="12"
                                FontWeight="SemiBold"
                                TextWrapping="Wrap"
                                Visibility="{Binding IsRegisterPasswordInvalid, Converter={StaticResource BooleanToVisibilityConverter}}" />

                            <PasswordBox
                                x:Name="RegisterPasswordConfirmationBox"
                                Header="Повторите пароль"
                                BorderBrush="{Binding IsRegisterPasswordConfirmationInvalid, Converter={StaticResource BooleanToValidationBrushConverter}}"
                                BorderThickness="2"
                                LostFocus="RegisterPasswordConfirmationBox_LostFocus"
                                PasswordChanged="RegisterPasswordConfirmationBox_PasswordChanged" />
                            <TextBlock
                                Text="{Binding RegisterPasswordConfirmationHint}"
                                Foreground="#C42B1C"
                                FontSize="12"
                                FontWeight="SemiBold"
                                Visibility="{Binding IsRegisterPasswordConfirmationInvalid, Converter={StaticResource BooleanToVisibilityConverter}}" />

                            <Button Command="{Binding RegisterCommand}" Style="{StaticResource PrimaryButtonStyle}" HorizontalAlignment="Stretch">
                                <StackPanel Orientation="Horizontal" Spacing="7" HorizontalAlignment="Center">
                                    <SymbolIcon Symbol="Accept" Foreground="{StaticResource InkBrush}" />
                                    <TextBlock Text="Создать профиль" FontWeight="Bold" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <Grid x:Name="AdminRoot" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border x:Name="AdminHeaderBorder" Grid.Row="0" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="0,0,0,1" Padding="22,18">
                <Grid x:Name="AdminHeaderGrid" ColumnSpacing="18" RowSpacing="10">
                    <Grid.RowDefinitions>
                        <RowDefinition x:Name="AdminHeaderMainRow" Height="Auto" />
                        <RowDefinition x:Name="AdminHeaderActionRow" Height="0" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition x:Name="AdminHeaderMainColumn" Width="*" />
                        <ColumnDefinition x:Name="AdminHeaderActionColumn" Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel x:Name="AdminHeaderIdentityPanel" Orientation="Horizontal" Spacing="14" VerticalAlignment="Center">
                        <Image x:Name="AdminHeaderLogo" Source="Assets/BrandLogo.png" Width="92" Height="92" Stretch="Uniform" />
                        <StackPanel VerticalAlignment="Center" Spacing="2">
                            <TextBlock Text="Администрирование склада" Style="{StaticResource SectionTitleTextStyle}" />
                            <TextBlock Text="Пополнение остатков товаров Knitty Kitty" Style="{StaticResource MutedTextStyle}" FontSize="14" />
                        </StackPanel>
                    </StackPanel>

                    <Button
                        x:Name="AdminLogoutButton"
                        Grid.Column="1"
                        Click="AdminLogoutButton_Click"
                        Style="{StaticResource QuietButtonStyle}"
                        VerticalAlignment="Center"
                        ToolTipService.ToolTip="Вернуться к авторизации">
                        <StackPanel Orientation="Horizontal" Spacing="7">
                            <SymbolIcon Symbol="Back" Foreground="{StaticResource MutedBrush}" />
                            <TextBlock Text="Выйти" Foreground="{StaticResource MutedBrush}" />
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <InfoBar
                x:Name="AdminStatusBar"
                Grid.Row="1"
                Margin="18,12,18,0"
                IsOpen="{Binding HasStatusMessage}"
                Severity="{Binding StatusSeverity}"
                Title="{Binding StatusTitle}"
                Message="{Binding StatusMessage}" />

            <Grid x:Name="AdminContentGrid" Grid.Row="2" Padding="18" ColumnSpacing="14" RowSpacing="0">
                <Grid.RowDefinitions>
                    <RowDefinition x:Name="AdminContentFirstRow" Height="*" />
                    <RowDefinition x:Name="AdminContentSecondRow" Height="0" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="AdminInventoryColumn" Width="2*" />
                    <ColumnDefinition x:Name="AdminActionColumn" Width="1*" />
                </Grid.ColumnDefinitions>

                <Border x:Name="AdminInventoryPanel" Background="{StaticResource AdminInventoryPanelBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="8" Padding="16">
                    <Grid RowSpacing="14">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid x:Name="AdminInventoryHeaderGrid" ColumnSpacing="12" RowSpacing="10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition x:Name="AdminInventoryHeaderActionRow" Height="0" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition x:Name="AdminInventoryActionColumn" Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Border Width="12" Height="56" Background="{StaticResource PaymentAccentBrush}" CornerRadius="6" />
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                <TextBlock Text="Товары на складе" Style="{StaticResource SectionTitleTextStyle}" />
                                <StackPanel x:Name="AdminInventorySubheadingPanel" Orientation="Horizontal" Spacing="8">
                                    <TextBlock x:Name="AdminInventorySubtitleText" Text="Выберите позицию и пополните остаток" Foreground="{StaticResource PaymentTextBrush}" TextWrapping="Wrap" />
                                    <TextBlock x:Name="AdminInventorySubtitleSeparator" Text="·" Foreground="{StaticResource SubtleBrush}" />
                                    <TextBlock x:Name="AdminInventoryResultTextBlock" Text="{Binding AdminResultText}" Foreground="{StaticResource SubtleBrush}" TextWrapping="Wrap" />
                                </StackPanel>
                            </StackPanel>

                            <Button x:Name="AdminReloadButton" Grid.Column="2" Command="{Binding ReloadProductsCommand}" Style="{StaticResource QuietButtonStyle}" ToolTipService.ToolTip="Перезагрузить склад">
                                <StackPanel Orientation="Horizontal" Spacing="7">
                                    <SymbolIcon Symbol="Refresh" Foreground="{StaticResource MutedBrush}" />
                                    <TextBlock Text="Обновить" Foreground="{StaticResource MutedBrush}" />
                                </StackPanel>
                            </Button>
                        </Grid>

                        <Grid x:Name="AdminFiltersGrid" Grid.Row="1" ColumnSpacing="10" RowSpacing="10">
                            <Grid.RowDefinitions>
                                <RowDefinition x:Name="AdminFiltersFirstRow" Height="Auto" />
                                <RowDefinition x:Name="AdminFiltersSecondRow" Height="0" />
                                <RowDefinition x:Name="AdminFiltersThirdRow" Height="0" />
                                <RowDefinition x:Name="AdminFiltersFourthRow" Height="0" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition x:Name="AdminSearchColumn" Width="2*" />
                                <ColumnDefinition x:Name="AdminCategoryColumn" Width="1.1*" />
                                <ColumnDefinition x:Name="AdminSortColumn" Width="1.65*" />
                                <ColumnDefinition x:Name="AdminClearColumn" Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBox
                                x:Name="AdminSearchBox"
                                Header="Поиск"
                                PlaceholderText="Название, описание или категория"
                                Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <ComboBox
                                x:Name="AdminCategoryBox"
                                Grid.Column="1"
                                Header="Категория"
                                ItemsSource="{Binding Categories}"
                                SelectedItem="{Binding SelectedCategory, Mode=TwoWay}"
                                HorizontalAlignment="Stretch" />

                            <ComboBox
                                x:Name="AdminSortBox"
                                Grid.Column="2"
                                Header="Сортировка"
                                ItemsSource="{Binding SortOptions}"
                                SelectedItem="{Binding SelectedSortOption, Mode=TwoWay}"
                                MinWidth="220"
                                HorizontalAlignment="Stretch" />

                            <Button
                                x:Name="AdminClearFiltersButton"
                                Grid.Column="3"
                                VerticalAlignment="Bottom"
                                Command="{Binding ClearAdminFiltersCommand}"
                                Opacity="{Binding HasAdminFilters, Converter={StaticResource BooleanToOpacityConverter}}"
                                Width="42"
                                MinWidth="42"
                                Padding="0"
                                Style="{StaticResource QuietButtonStyle}"
                                ToolTipService.ToolTip="Сбросить поиск, фильтр и сортировку">
                                <SymbolIcon Symbol="Clear" Foreground="{StaticResource MutedBrush}" />
                            </Button>
                        </Grid>

                        <ListView
                            Grid.Row="2"
                            Background="Transparent"
                            BorderThickness="0"
                            ItemsSource="{Binding Products}"
                            SelectedItem="{Binding SelectedProduct, Mode=TwoWay}"
                            SelectionMode="Single">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{StaticResource SoftSurfaceBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="8" Margin="0,0,0,8" Padding="12">
                                        <Grid ColumnSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="96" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <Border Background="{StaticResource MediaSurfaceBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="8" Width="96" Height="78">
                                                <Image Source="{Binding Image}" Stretch="UniformToFill" />
                                            </Border>

                                            <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="Bold" TextWrapping="Wrap" />
                                                <TextBlock Text="{Binding Category}" Style="{StaticResource MutedTextStyle}" />
                                                <TextBlock Text="{Binding StockText}" Style="{StaticResource NumericTextStyle}" Foreground="#0B78A9" />
                                            </StackPanel>

                                            <Border Grid.Column="2" Background="{StaticResource PaymentSoftAccentBrush}" CornerRadius="8" Padding="9,5" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding PriceText}" Style="{StaticResource NumericTextStyle}" FontSize="13" Foreground="{StaticResource PaymentTextBrush}" />
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Border>

                <Border x:Name="AdminActionPanel" Grid.Column="1" Background="{StaticResource AdminActionPanelBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="8" Padding="16">
                    <Grid RowSpacing="14">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Width="12" Height="56" Background="{StaticResource CatalogAccentBrush}" CornerRadius="6" />
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                <TextBlock Text="Пополнение" Style="{StaticResource SectionTitleTextStyle}" />
                                <TextBlock Text="Увеличение остатка выбранного товара" Foreground="{StaticResource CatalogTextBrush}" TextWrapping="Wrap" />
                            </StackPanel>
                        </Grid>

                        <Border Grid.Row="1" Background="{StaticResource CatalogSoftAccentBrush}" BorderBrush="#DDEE77" BorderThickness="1" CornerRadius="8" Padding="12">
                            <StackPanel Spacing="4">
                                <TextBlock Text="{Binding SelectedProduct.Name}" FontWeight="Bold" TextWrapping="Wrap" />
                                <TextBlock Text="{Binding SelectedProduct.StockText}" Style="{StaticResource NumericTextStyle}" Foreground="{StaticResource CatalogTextBrush}" />
                            </StackPanel>
                        </Border>

                        <NumberBox
                            Grid.Row="2"
                            Header="Добавить на склад"
                            Minimum="0"
                            Value="{Binding RestockAmount, Mode=TwoWay}"
                            SpinButtonPlacementMode="Inline" />

                        <Button
                            Grid.Row="3"
                            Command="{Binding RestockCommand}"
                            Opacity="{Binding CanRestockSelectedProduct, Converter={StaticResource BooleanToOpacityConverter}}"
                            Style="{StaticResource PrimaryButtonStyle}"
                            HorizontalAlignment="Stretch">
                            <StackPanel Orientation="Horizontal" Spacing="7" HorizontalAlignment="Center">
                                <SymbolIcon Symbol="Add" Foreground="{StaticResource InkBrush}" />
                                <TextBlock Text="Пополнить остаток" FontWeight="Bold" />
                            </StackPanel>
                        </Button>

                        <TextBlock
                            Grid.Row="4"
                            Text="{Binding RestockHint}"
                            Style="{StaticResource MutedTextStyle}"
                            FontSize="12"
                            FontWeight="SemiBold"
                            Visibility="{Binding HasRestockHint, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <Grid x:Name="ShopRoot" Visibility="Collapsed">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border x:Name="ShopHeaderBorder" Grid.Row="0" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="0,0,0,1" Padding="12,18,22,18">
            <Grid x:Name="ShopHeaderGrid" ColumnSpacing="20" RowSpacing="12">
                <Grid.RowDefinitions>
                    <RowDefinition x:Name="ShopHeaderTopRow" Height="Auto" />
                    <RowDefinition x:Name="ShopHeaderBottomRow" Height="0" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="ShopHeaderLogoColumn" Width="Auto" />
                    <ColumnDefinition x:Name="ShopHeaderActionsColumn" Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel x:Name="ShopLogoPanel" Grid.Column="0" Orientation="Horizontal" Spacing="14" HorizontalAlignment="Left" VerticalAlignment="Center">
                    <Image x:Name="ShopHeaderLogo" Source="Assets/ShopHeaderLogo.png" Width="300" Height="134" Stretch="Uniform" />
                </StackPanel>

                <StackPanel x:Name="ShopHeaderActionsPanel" Grid.Column="1" Spacing="10" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock
                        x:Name="GreetingTextBlock"
                        Text="{Binding GreetingText}"
                        FontSize="20"
                        FontWeight="Bold"
                        TextWrapping="WrapWholeWords"
                        HorizontalAlignment="Right"
                        TextAlignment="Right" />

                    <Grid x:Name="BalanceGrid" ColumnSpacing="10" RowSpacing="8" HorizontalAlignment="Right">
                        <Grid.RowDefinitions>
                            <RowDefinition x:Name="BalanceTopRow" Height="Auto" />
                            <RowDefinition x:Name="BalanceBottomRow" Height="0" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition x:Name="BalanceCashColumn" Width="132" />
                            <ColumnDefinition x:Name="BalanceCardColumn" Width="132" />
                            <ColumnDefinition x:Name="BalanceBonusColumn" Width="132" />
                            <ColumnDefinition x:Name="BalanceActionColumn" Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Border x:Name="CashBalanceCard" Background="{StaticResource SoftLimeBrush}" BorderBrush="#DDEE77" BorderThickness="1" CornerRadius="8" Padding="12,9">
                            <StackPanel>
                                <TextBlock Text="Наличные" Foreground="{StaticResource MutedBrush}" FontSize="12" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding CashBalanceText}" Style="{StaticResource NumericTextStyle}" FontSize="16" />
                            </StackPanel>
                        </Border>

                        <Border x:Name="CardBalanceCard" Grid.Column="1" Background="{StaticResource SoftPinkBrush}" BorderBrush="#FFD3F1" BorderThickness="1" CornerRadius="8" Padding="12,9">
                            <StackPanel>
                                <TextBlock Text="Карта" Foreground="{StaticResource MutedBrush}" FontSize="12" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding CardBalanceText}" Style="{StaticResource NumericTextStyle}" FontSize="16" />
                            </StackPanel>
                        </Border>

                        <Border x:Name="BonusBalanceCard" Grid.Column="2" Background="{StaticResource SoftBlueBrush}" BorderBrush="#BDEAFF" BorderThickness="1" CornerRadius="8" Padding="12,9">
                            <StackPanel>
                                <TextBlock Text="Бонусы" Foreground="{StaticResource MutedBrush}" FontSize="12" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding BonusBalanceText}" Style="{StaticResource NumericTextStyle}" FontSize="16" />
                            </StackPanel>
                        </Border>

                        <Button
                            x:Name="LogoutButton"
                            Grid.Column="3"
                            Click="LogoutButton_Click"
                            Style="{StaticResource QuietButtonStyle}"
                            MinWidth="42"
                            Padding="10,8"
                            VerticalAlignment="Center"
                            ToolTipService.ToolTip="Выйти из аккаунта">
                            <StackPanel Orientation="Horizontal" Spacing="7">
                                <SymbolIcon Symbol="Back" Foreground="{StaticResource MutedBrush}" />
                                <TextBlock Text="Выйти" Foreground="{StaticResource MutedBrush}" />
                            </StackPanel>
                        </Button>
                    </Grid>
                </StackPanel>
            </Grid>
        </Border>

        <InfoBar
            x:Name="ShopStatusBar"
            Grid.Row="1"
            Margin="18,12,18,0"
            IsOpen="{Binding HasStatusMessage}"
            Severity="{Binding StatusSeverity}"
            Title="{Binding StatusTitle}"
            Message="{Binding StatusMessage}" />

        <Grid x:Name="ShopContentGrid" Grid.Row="2" Padding="18" ColumnSpacing="14" RowSpacing="0">
            <Grid.RowDefinitions>
                <RowDefinition x:Name="ShopContentFirstRow" Height="*" />
                <RowDefinition x:Name="ShopContentSecondRow" Height="0" />
                <RowDefinition x:Name="ShopContentThirdRow" Height="0" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="ShopCatalogColumn" Width="2.1*" />
                <ColumnDefinition x:Name="ShopCartColumn" Width="1.25*" />
                <ColumnDefinition x:Name="ShopPaymentColumn" Width="1.25*" />
            </Grid.ColumnDefinitions>

            <Border x:Name="CatalogPanel" Grid.Column="0" Background="{StaticResource CatalogPanelBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="8" Padding="16">
                <Grid RowSpacing="14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid x:Name="CatalogHeaderGrid" ColumnSpacing="12" RowSpacing="10">
                        <Grid.RowDefinitions>
                            <RowDefinition x:Name="CatalogHeaderTopRow" Height="Auto" />
                            <RowDefinition x:Name="CatalogHeaderActionRow" Height="0" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition x:Name="CatalogAccentColumn" Width="Auto" />
                            <ColumnDefinition x:Name="CatalogTitleColumn" Width="*" />
                            <ColumnDefinition x:Name="CatalogActionColumn" Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Border Width="12" Height="56" Background="{StaticResource LimeBrush}" CornerRadius="6" />
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                            <TextBlock Text="Каталог" Style="{StaticResource SectionTitleTextStyle}" />
                            <StackPanel x:Name="CatalogSubheadingPanel" Orientation="Horizontal" Spacing="8">
                                <TextBlock x:Name="CatalogSubtitleText" Text="Игрушки, сумки, одежда и материалы" Style="{StaticResource MutedTextStyle}" TextWrapping="Wrap" />
                                <TextBlock x:Name="CatalogSubtitleSeparator" Text="·" Foreground="{StaticResource SubtleBrush}" />
                                <TextBlock x:Name="CatalogResultTextBlock" Text="{Binding CatalogResultText}" Foreground="{StaticResource SubtleBrush}" TextWrapping="Wrap" />
                            </StackPanel>
                        </StackPanel>

                        <Button x:Name="CatalogReloadButton" Grid.Column="2" Command="{Binding ReloadProductsCommand}" Style="{StaticResource QuietButtonStyle}" ToolTipService.ToolTip="Перезагрузить каталог">
                            <StackPanel Orientation="Horizontal" Spacing="7">
                                <SymbolIcon Symbol="Refresh" Foreground="{StaticResource MutedBrush}" />
                                <TextBlock Text="Обновить" Foreground="{StaticResource MutedBrush}" />
                            </StackPanel>
                        </Button>
                    </Grid>

                    <Grid x:Name="CatalogFiltersGrid" Grid.Row="1" ColumnSpacing="10" RowSpacing="10">
                        <Grid.RowDefinitions>
                            <RowDefinition x:Name="CatalogFiltersFirstRow" Height="Auto" />
                            <RowDefinition x:Name="CatalogFiltersSecondRow" Height="0" />
                            <RowDefinition x:Name="CatalogFiltersThirdRow" Height="0" />
                            <RowDefinition x:Name="CatalogFiltersFourthRow" Height="0" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition x:Name="CatalogSearchColumn" Width="2*" />
                            <ColumnDefinition x:Name="CatalogCategoryColumn" Width="1.1*" />
                            <ColumnDefinition x:Name="CatalogSortColumn" Width="1.65*" />
                            <ColumnDefinition x:Name="CatalogClearColumn" Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBox
                            x:Name="CatalogSearchBox"
                            Header="Поиск"
                            PlaceholderText="Название, описание или категория"
                            Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <ComboBox
                            x:Name="CatalogCategoryBox"
                            Grid.Column="1"
                            Header="Категория"
                            ItemsSource="{Binding Categories}"
                            SelectedItem="{Binding SelectedCategory, Mode=TwoWay}"
                            HorizontalAlignment="Stretch" />

                        <ComboBox
                            x:Name="CatalogSortBox"
                            Grid.Column="2"
                            Header="Сортировка"
                            ItemsSource="{Binding SortOptions}"
                            SelectedItem="{Binding SelectedSortOption, Mode=TwoWay}"
                            MinWidth="220"
                            HorizontalAlignment="Stretch" />

                        <Button
                            x:Name="CatalogClearFiltersButton"
                            Grid.Column="3"
                            VerticalAlignment="Bottom"
                            Command="{Binding ClearCatalogFiltersCommand}"
                            Opacity="{Binding HasCatalogFilters, Converter={StaticResource BooleanToOpacityConverter}}"
                            Width="42"
                            MinWidth="42"
                            Padding="0"
                            Style="{StaticResource QuietButtonStyle}"
                            ToolTipService.ToolTip="Сбросить поиск, фильтр и сортировку">
                            <SymbolIcon Symbol="Clear" Foreground="{StaticResource MutedBrush}" />
                        </Button>
                    </Grid>

                    <ListView
                        Grid.Row="2"
                        Background="Transparent"
                        BorderThickness="0"
                        ItemsSource="{Binding Products}"
                        SelectedItem="{Binding SelectedProduct, Mode=TwoWay}"
                        SelectionMode="Single">
                        <ListView.Resources>
                            <SolidColorBrush x:Key="ListViewItemSelectedBackground" Color="#F3F8CE" />
                            <SolidColorBrush x:Key="ListViewItemSelectedPointerOverBackground" Color="#EEF5B8" />
                            <SolidColorBrush x:Key="ListViewItemSelectedPressedBackground" Color="#E5F19B" />
                            <SolidColorBrush x:Key="ListViewItemSelectedForeground" Color="#111318" />
                            <SolidColorBrush x:Key="ListViewItemSelectedPointerOverForeground" Color="#111318" />
                            <SolidColorBrush x:Key="ListViewItemSelectedPressedForeground" Color="#111318" />
                        </ListView.Resources>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource SoftSurfaceBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="8" Margin="0,0,0,8" Padding="12">
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="128" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <Border Background="{StaticResource MediaSurfaceBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="8" Width="128" Height="104">
                                            <Image Source="{Binding Image}" Stretch="UniformToFill" />
                                        </Border>

                                        <Grid Grid.Column="1" RowSpacing="6">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="Bold" TextWrapping="Wrap" />
                                            <Border Grid.Column="1" Background="{StaticResource SoftLimeBrush}" CornerRadius="8" Padding="9,5">
                                                <TextBlock Text="{Binding PriceText}" Style="{StaticResource NumericTextStyle}" FontSize="13" Foreground="#687900" />
                                            </Border>

                                            <TextBlock Grid.Row="1" Grid.ColumnSpan="2" Text="{Binding Description}" Style="{StaticResource MutedTextStyle}" TextWrapping="Wrap" />

                                            <Grid Grid.Row="2" Grid.ColumnSpan="2" ColumnSpacing="8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <Border Background="{StaticResource SoftLimeBrush}" CornerRadius="8" Padding="8,4">
                                                    <TextBlock Text="{Binding Category}" Foreground="#687900" FontSize="12" FontWeight="SemiBold" />
                                                </Border>
                                                <Border Grid.Column="1" Background="#F0F3F8" CornerRadius="8" Padding="8,4">
                                                    <TextBlock Text="{Binding StockText}" Foreground="{StaticResource MutedBrush}" FontSize="12" />
                                                </Border>
                                                <Border Grid.Column="2" Background="{StaticResource SoftLimeBrush}" CornerRadius="8" Padding="8,4">
                                                    <TextBlock Text="{Binding WeighingText}" Foreground="#687900" FontSize="12" FontWeight="SemiBold" />
                                                </Border>
                                            </Grid>

                                            <StackPanel
                                                Grid.Row="3"
                                                Grid.ColumnSpan="2"
                                                Orientation="Horizontal"
                                                Spacing="8"
                                                Margin="0,4,0,0"
                                                Visibility="{Binding HasColorOptions, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <TextBlock Text="Цвет" VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}" FontWeight="SemiBold" />
                                                <ItemsControl ItemsSource="{Binding ColorOptions}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <StackPanel Orientation="Horizontal" Spacing="6" />
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Button
                                                                Style="{StaticResource ColorSwatchButtonStyle}"
                                                                Command="{Binding SelectCommand}"
                                                                ToolTipService.ToolTip="{Binding Name}">
                                                                <Grid Width="28" Height="28">
                                                                    <Ellipse
                                                                        Fill="{Binding Name, Converter={StaticResource ColorNameToBrushConverter}}"
                                                                        Stroke="{StaticResource LineBrush}"
                                                                        StrokeThickness="1" />
                                                                    <Ellipse
                                                                        Stroke="{StaticResource InkBrush}"
                                                                        StrokeThickness="2.5"
                                                                        Visibility="{Binding IsSelected, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                                                </Grid>
                                                            </Button>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                                <TextBlock Text="{Binding SelectedColor}" VerticalAlignment="Center" Foreground="{StaticResource SubtleBrush}" FontSize="12" />
                                            </StackPanel>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <Grid x:Name="CatalogActionGrid" Grid.Row="3" ColumnSpacing="10" RowSpacing="10">
                        <Grid.RowDefinitions>
                            <RowDefinition x:Name="CatalogActionFirstRow" Height="Auto" />
                            <RowDefinition x:Name="CatalogActionSecondRow" Height="0" />
                            <RowDefinition x:Name="CatalogActionThirdRow" Height="0" />
                            <RowDefinition x:Name="CatalogActionFourthRow" Height="0" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition x:Name="CatalogQuantityColumn" Width="*" />
                            <ColumnDefinition x:Name="CatalogWeightColumn" Width="*" />
                            <ColumnDefinition x:Name="CatalogWeighColumn" Width="Auto" />
                            <ColumnDefinition x:Name="CatalogAddColumn" Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <NumberBox
                            x:Name="QuantityBox"
                            Header="Количество, шт."
                            Minimum="1"
                            Value="{Binding QuantityToAdd, Mode=TwoWay}"
                            IsEnabled="{Binding CanEditQuantity}"
                            Opacity="{Binding CanEditQuantity, Converter={StaticResource BooleanToOpacityConverter}}"
                            SpinButtonPlacementMode="Inline" />
                        <NumberBox
                            x:Name="WeightBox"
                            Grid.Column="1"
                            Header="Вес, г."
                            Minimum="1"
                            Value="{Binding WeightToAddGrams, Mode=TwoWay}"
                            IsEnabled="{Binding CanEditWeight}"
                            Opacity="{Binding CanEditWeight, Converter={StaticResource BooleanToOpacityConverter}}"
                            SpinButtonPlacementMode="Inline" />

                        <Button x:Name="WeighButton" Grid.Column="2" VerticalAlignment="Bottom" Command="{Binding WeighCommand}" Opacity="{Binding CanWeighSelectedProduct, Converter={StaticResource BooleanToOpacityConverter}}" Style="{StaticResource CatalogQuietButtonStyle}" ToolTipService.ToolTip="Взвесить выбранный товар">
                            <StackPanel Orientation="Horizontal" Spacing="7">
                                <SymbolIcon Symbol="Calculator" Foreground="{StaticResource InkBrush}" />
                                <TextBlock Text="Взвесить" />
                            </StackPanel>
                        </Button>

                        <Button x:Name="AddToCartButton" Grid.Column="3" VerticalAlignment="Bottom" Command="{Binding AddToCartCommand}" Opacity="{Binding CanAddSelectedProduct, Converter={StaticResource BooleanToOpacityConverter}}" Style="{StaticResource PrimaryButtonStyle}" ToolTipService.ToolTip="Добавить выбранный товар в корзину">
                            <StackPanel Orientation="Horizontal" Spacing="7">
                                <SymbolIcon Symbol="Add" Foreground="{StaticResource InkBrush}" />
                                <TextBlock Text="В корзину" FontWeight="Bold" />
                            </StackPanel>
                        </Button>
                    </Grid>

                    <TextBlock
                        Grid.Row="4"
                        Text="{Binding ProductActionHint}"
                        Style="{StaticResource MutedTextStyle}"
                        FontSize="12"
                        FontWeight="SemiBold"
                        Visibility="{Binding HasProductActionHint, Converter={StaticResource BooleanToVisibilityConverter}}" />
                </Grid>
            </Border>

            <Border x:Name="CartPanel" Grid.Column="1" Background="{StaticResource CartPanelBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="8" Padding="16">
                <Grid RowSpacing="14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Width="12" Height="56" Background="{StaticResource CartAccentBrush}" CornerRadius="6" />
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                            <TextBlock Text="Корзина" Style="{StaticResource SectionTitleTextStyle}" />
                            <TextBlock Text="{Binding CartTotalText}" Style="{StaticResource NumericTextStyle}" Foreground="{StaticResource CartTextBrush}" FontSize="17" />
                        </StackPanel>
                    </Grid>

                    <ListView
                        Grid.Row="1"
                        Background="Transparent"
                        BorderThickness="0"
                        ItemsSource="{Binding CartLines}"
                        SelectedItem="{Binding SelectedCartLine, Mode=TwoWay}"
                        SelectionMode="Single">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource SoftSurfaceBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="8" Margin="0,0,0,8" Padding="10">
                                    <Grid RowSpacing="4">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Name}" FontWeight="Bold" TextWrapping="Wrap" />
                                        <TextBlock Grid.Column="1" Text="{Binding TotalText}" Style="{StaticResource NumericTextStyle}" Foreground="{StaticResource CartTextBrush}" />
                                        <TextBlock Grid.Row="1" Grid.ColumnSpan="2" Text="{Binding AmountText}" Style="{StaticResource MutedTextStyle}" />
                                        <TextBlock
                                            Grid.Row="2"
                                            Grid.ColumnSpan="2"
                                            Text="{Binding ColorText}"
                                            Foreground="{StaticResource CartTextBrush}"
                                            FontWeight="SemiBold"
                                            Visibility="{Binding HasColor, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <Grid Grid.Row="2" ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Button Command="{Binding RemoveFromCartCommand}" Opacity="{Binding HasSelectedCartLine, Converter={StaticResource BooleanToOpacityConverter}}" Style="{StaticResource DangerQuietButtonStyle}" HorizontalAlignment="Stretch" ToolTipService.ToolTip="Выложить выбранный товар">
                            <StackPanel Orientation="Horizontal" Spacing="7" HorizontalAlignment="Center">
                                <SymbolIcon Symbol="Delete" Foreground="{StaticResource InkBrush}" />
                                <TextBlock Text="Выложить" />
                            </StackPanel>
                        </Button>

                        <Button Grid.Column="1" Command="{Binding ClearCartCommand}" Opacity="{Binding HasCartItems, Converter={StaticResource BooleanToOpacityConverter}}" Style="{StaticResource DangerQuietButtonStyle}" HorizontalAlignment="Stretch" ToolTipService.ToolTip="Очистить всю корзину">
                            <StackPanel Orientation="Horizontal" Spacing="7" HorizontalAlignment="Center">
                                <SymbolIcon Symbol="Clear" Foreground="{StaticResource InkBrush}" />
                                <TextBlock Text="Очистить всё" />
                            </StackPanel>
                        </Button>
                    </Grid>

                    <TextBlock
                        Grid.Row="3"
                        Text="{Binding CartActionHint}"
                        Style="{StaticResource MutedTextStyle}"
                        FontSize="12"
                        FontWeight="SemiBold"
                        Visibility="{Binding HasCartActionHint, Converter={StaticResource BooleanToVisibilityConverter}}" />
                </Grid>
            </Border>

            <Border x:Name="PaymentPanel" Grid.Column="2" Background="{StaticResource PaymentPanelBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="8" Padding="16">
                <Grid RowSpacing="14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Width="12" Height="56" Background="{StaticResource PaymentAccentBrush}" CornerRadius="6" />
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                            <TextBlock Text="Оплата" Style="{StaticResource SectionTitleTextStyle}" />
                            <TextBlock Text="Наличные, карта, бонусы" Style="{StaticResource MutedTextStyle}" />
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Row="1" RowSpacing="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <NumberBox Header="Бонусами" Minimum="0" Value="{Binding BonusPayment, Mode=TwoWay}" IsEnabled="{Binding HasCartItems}" Opacity="{Binding HasCartItems, Converter={StaticResource BooleanToOpacityConverter}}" SpinButtonPlacementMode="Inline" />
                        <NumberBox Grid.Row="1" Header="Дебетовой картой" Minimum="0" Value="{Binding CardPayment, Mode=TwoWay}" IsEnabled="{Binding HasCartItems}" Opacity="{Binding HasCartItems, Converter={StaticResource BooleanToOpacityConverter}}" SpinButtonPlacementMode="Inline" />
                        <NumberBox Grid.Row="2" Header="Наличными" Minimum="0" Value="{Binding CashPayment, Mode=TwoWay}" IsEnabled="{Binding HasCartItems}" Opacity="{Binding HasCartItems, Converter={StaticResource BooleanToOpacityConverter}}" SpinButtonPlacementMode="Inline" />
                    </Grid>

                    <Grid Grid.Row="2" ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button Command="{Binding FillCardPaymentCommand}" Opacity="{Binding HasCartItems, Converter={StaticResource BooleanToOpacityConverter}}" Style="{StaticResource SecondaryButtonStyle}" HorizontalAlignment="Stretch" ToolTipService.ToolTip="Заполнить оплату картой">
                            <StackPanel Orientation="Horizontal" Spacing="7" HorizontalAlignment="Center">
                                <SymbolIcon Symbol="Shop" Foreground="{StaticResource InkBrush}" />
                                <TextBlock Text="Картой" />
                            </StackPanel>
                        </Button>
                        <Button Grid.Column="1" Command="{Binding FillMixedPaymentCommand}" Opacity="{Binding HasCartItems, Converter={StaticResource BooleanToOpacityConverter}}" Style="{StaticResource PaymentQuietButtonStyle}" HorizontalAlignment="Stretch" ToolTipService.ToolTip="Заполнить оплату бонусами, картой и наличными">
                            <StackPanel Orientation="Horizontal" Spacing="7" HorizontalAlignment="Center">
                                <SymbolIcon Symbol="Calculator" Foreground="{StaticResource InkBrush}" />
                                <TextBlock Text="Смешанная" />
                            </StackPanel>
                        </Button>
                    </Grid>

                    <Button Grid.Row="3" Command="{Binding CheckoutCommand}" Opacity="{Binding HasCartItems, Converter={StaticResource BooleanToOpacityConverter}}" HorizontalAlignment="Stretch" Style="{StaticResource CheckoutButtonStyle}" ToolTipService.ToolTip="Совершить покупку и сохранить чек">
                        <StackPanel Orientation="Horizontal" Spacing="7" HorizontalAlignment="Center">
                            <SymbolIcon Symbol="Accept" Foreground="{StaticResource InkBrush}" />
                            <TextBlock Text="Купить и сохранить чек" FontWeight="Bold" />
                        </StackPanel>
                    </Button>

                    <TextBlock
                        Grid.Row="4"
                        Text="{Binding PaymentActionHint}"
                        Style="{StaticResource MutedTextStyle}"
                        FontSize="12"
                        FontWeight="SemiBold"
                        Visibility="{Binding HasPaymentActionHint, Converter={StaticResource BooleanToVisibilityConverter}}" />

                    <Grid Grid.Row="5" RowSpacing="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="История покупок за сессию" FontWeight="Bold" />
                        <ListView Grid.Row="1" Background="Transparent" BorderThickness="0" ItemsSource="{Binding PurchaseHistory}">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{StaticResource SoftSurfaceBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="8" Margin="0,0,0,8" Padding="10">
                                        <StackPanel Spacing="3">
                                            <TextBlock Text="{Binding Summary}" FontWeight="Bold" TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding PaymentsText}" Style="{StaticResource MutedTextStyle}" TextWrapping="Wrap" />
                                            <HyperlinkButton
                                                Padding="0"
                                                HorizontalAlignment="Left"
                                                Command="{Binding OpenReceiptCommand}"
                                                Content="{Binding ReceiptLinkText}"
                                                Foreground="#A31778"
                                                ToolTipService.ToolTip="{Binding FilePath}" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
    </Grid>
</Window>
